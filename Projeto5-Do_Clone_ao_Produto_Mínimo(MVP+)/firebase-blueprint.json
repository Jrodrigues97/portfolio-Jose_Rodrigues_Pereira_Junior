{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User account information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user ID" },
        "email": { "type": "string", "format": "email", "description": "User email address" },
        "displayName": { "type": "string", "description": "User's full name" },
        "photoURL": { "type": "string", "format": "uri", "description": "User's profile picture URL" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user joined" }
      },
      "required": ["uid", "email"]
    },
    "QRCode": {
      "title": "QR Code",
      "description": "A saved QR code design",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique QR ID" },
        "userId": { "type": "string", "description": "Owner's UID" },
        "name": { "type": "string", "description": "Name given to the QR code" },
        "options": { "type": "object", "description": "The configuration options for the QR code" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the QR was created" }
      },
      "required": ["id", "userId", "options"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Stores user profile data"
    },
    "/users/{userId}/qrcodes/{qrId}": {
      "schema": "QRCode",
      "description": "Stores saved QR codes for a user"
    }
  }
}
